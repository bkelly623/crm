# =============================================================================
# CRM Environment Variables
# Copy to .env.local for local dev and set in Vercel → Settings → Environment Variables
# =============================================================================

# --- Supabase (required) ---
# Project URL from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fzjsgerhohsfxwsqkjdu.supabase.co

# anon/public key — safe for browser (Dashboard → Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (required for Prisma) ---
# Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" pooler (port 6543) for DATABASE_URL on Vercel:
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Use "Session" direct connection (port 5432) for migrations:
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- App (required) ---
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Twilio (Phase 1 dialer — add when ready) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=

# --- Go High Level (optional — Phase 2 integration) ---
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# --- Stripe (optional — Phase 3 payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Google Calendar (optional — Phase 2 appointments) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
