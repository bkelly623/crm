# =============================================================================
# CRM — Environment Variables (July 2026)
# Copy to .env.local locally. Set the same keys in Vercel → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Project: https://supabase.com/dashboard/project/fzjsgerhohsfxwsqkjdu
# -----------------------------------------------------------------------------

# Project URL
# Dashboard → Project Settings (gear) → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://fzjsgerhohsfxwsqkjdu.supabase.co

# Publishable key (replaces legacy "anon" key)
# Dashboard → Project Settings → API Keys → tab "Publishable and secret API keys"
# Copy the key named "default" — starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (replaces legacy "service_role" key) — SERVER ONLY, never in client code
# Same page → Secret keys → "default" — starts with sb_secret_
SUPABASE_SECRET_KEY=

# Legacy fallbacks (only if your project still uses JWT keys under the "Legacy" tab):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Database — Prisma
# Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL = "Transaction pooler" (Supavisor, port 6543) — use for Vercel/runtime
# Add: ?pgbouncer=true&connection_limit=1
DATABASE_URL=

# DIRECT_URL = "Session mode" direct connection (port 5432) — use for prisma db push / migrate
DIRECT_URL=

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# TWILIO (Phase 1 dialer)
# Console: https://console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
# Optional: default outbound caller ID (E.164, e.g. +15551234567)
TWILIO_CALLER_ID=

# -----------------------------------------------------------------------------
# GO HIGH LEVEL (optional)
# -----------------------------------------------------------------------------
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# STRIPE (optional — Phase 3)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# GOOGLE CALENDAR (optional — Phase 2)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
