# =============================================================================
# CRM — Environment Variables (July 2026)
# =============================================================================
# If you connected Supabase ↔ Vercel (recommended), most vars sync automatically.
# Supabase Dashboard → Project Settings → Integrations → Vercel
# =============================================================================

# --- Supabase (client) ---
NEXT_PUBLIC_SUPABASE_URL=https://fzjsgerhohsfxwsqkjdu.supabase.co

# Dashboard → Project Settings → API Keys → "Publishable and secret API keys"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only — synced as SUPABASE_SECRET_KEY when Vercel integration is connected
SUPABASE_SECRET_KEY=

# --- Database (Prisma) — synced by Supabase ↔ Vercel integration ---
# POSTGRES_PRISMA_URL      = transaction pooler (port 6543)
# POSTGRES_URL_NON_POOLING = direct/session (port 5432)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Local-only aliases (optional if not using Vercel integration naming):
# POSTGRES_PRISMA_URL=<same as Supabase "Transaction pooler" connection string>
# POSTGRES_URL_NON_POOLING=<same as Supabase "Session mode" connection string>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Twilio (Phase 1) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=

# --- GHL (optional) ---
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
