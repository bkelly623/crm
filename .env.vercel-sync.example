# Copy to .env.vercel-sync (gitignored) or ~/.config/crm/deploy.env
# One-time setup — then agents/scripts can sync to Vercel without the dashboard.

# Create at https://vercel.com/account/tokens
# Scope: Full Account (or team with env write permission)
VERCEL_TOKEN=

# Supabase → Project Settings → API Keys → Secret keys → default
SUPABASE_SECRET_KEY=

# Supabase → Project Settings → Database → Connection string
# Transaction pooler (port 6543) — append ?pgbouncer=true if not present
POSTGRES_PRISMA_URL=

# Session mode / direct (port 5432)
POSTGRES_URL_NON_POOLING=

# Optional overrides (defaults are fine for this project)
# NEXT_PUBLIC_SUPABASE_URL=https://fzjsgerhohsfxwsqkjdu.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_APP_URL=https://crm-b-kellys-projects.vercel.app
# VERCEL_PROJECT_ID=prj_AoND6Ud9hrFjIQay40k14J2qO9p8
# VERCEL_TEAM_ID=team_NB981ddsKAGTAJtm4O1A14X1
# REDEPLOY=true
